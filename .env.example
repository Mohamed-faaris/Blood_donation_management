# ─── Database (pick one) ──────────────────
# Connection URL (takes priority over individual fields below)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Individual fields (fallback)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=blood_donation_db

# ─── App ─────────────────────────────────
PORT=3000

# ─── JWT ─────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=1d
